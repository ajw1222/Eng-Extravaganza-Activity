turtle.fillcolor(""black"")
turtle.pencolor(""black"")
turtle.penup()
turtle.goto(0, 105)
turtle.forward(20)
turtle.pendown()
turtle.begin_fill()
turtle.circle(9)
turtle.end_fill()

turtle.penup()
turtle.goto(-20, 105)
turtle.pendown()
turtle.begin_fill()
turtle.circle(9)
turtle.end_fill()

# --

turtle.speed(10)
# Draw the snowman's hat
turtle.penup()
turtle.fillcolor(""blue"")
turtle.pencolor(""orange"")
turtle.pensize(2)
turtle.goto(0, 135)
turtle.pendown()
turtle.begin_fill()
turtle.forward(60)
turtle.left(90)
turtle.forward(20)
turtle.left(60)
turtle.forward(40)
turtle.right(60)
turtle.forward(40)
turtle.left(90)

# top of hat length
turtle.forward(50)

turtle.left(90)
turtle.forward(40)
turtle.right(60)
turtle.forward(40)
turtle.left(60)
turtle.forward(20)
turtle.left(90)
turtle.forward(60)
turtle.end_fill()

