import turtle
turtle.showturtle()
turtle.speed(15)

# Move into starting position
turtle.penup()
turtle.right(90)
turtle.forward(175)
turtle.left(90)

# --

# Draw the 3 circles of the snowman's body
turtle.fillcolor(""white"")
turtle.pencolor(""black"")
turtle.pendown()
turtle.begin_fill()
turtle.circle(80)
turtle.end_fill()

turtle.penup()
turtle.left(90)
turtle.forward(140)
turtle.right(90)
turtle.pendown()
turtle.begin_fill()
turtle.circle(60)
turtle.end_fill()

turtle.penup()
turtle.left(90)
turtle.forward(100)
turtle.right(90)
turtle.pendown()
turtle.begin_fill()
turtle.circle(45)
turtle.end_fill()

# --

# Create the snowman's buttons
turtle.fillcolor(""orange"")
turtle.pencolor(""orange"")
turtle.penup()
turtle.goto(0, -20)
turtle.pendown()
turtle.begin_fill()
turtle.circle(11)
turtle.end_fill()

